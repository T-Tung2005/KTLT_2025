#include<bits/stdc++.h>
using namespace std;
#define ll long long
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n;
        cin>>n;
        vector<int>a(n),b(n);
        for(int i=0;i<n;i++) cin>>a[i];
        sort(a.begin(),a.end());
        for(int i=0;i<n;i++) cin>>b[i];
        sort(b.begin(),b.end(),greater<int>());
        ll tong=0;
        for(int i=0;i<n;i++)
        {
            ll tich=a[i]*b[i];
            tong+=tich;
        }
        cout<<tong<<endl;
    }
}
