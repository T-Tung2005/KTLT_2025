#include<bits/stdc++.h>
using namespace std;
int uutien(char c)
{
    if(c=='^') return 3;
    if(c=='*'||c=='/') return 2;
    if(c=='+'||c=='-') return 1;
    return 0;
}
string biendoi(string s)
{
    stack<char>st;
    string res="";
    for(char x: s)
    {
        if(isalnum(x))
        {
            res+=x;
        }else if(x=='(')
                 {
                     st.push(x);
                 }else if(x==')')
                 {
                     while(!st.empty()&&st.top()!='(')
                     {
                         res+=st.top();
                         st.pop();
                     }
                     if(!st.empty()) st.pop();
                 }else{
                   while(!st.empty()&&uutien(st.top())>=uutien(x))
                   {
                       res+=st.top();
                       st.pop();
                   }
                   st.push(x);
                 }
    }
    while(!st.empty())
    {
        res+=st.top();
        st.pop();
    }
    return res;
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        string s;
        cin>>s;
        cout<<biendoi(s)<<endl;
    }
}
