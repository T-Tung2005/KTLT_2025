#include<bits/stdc++.h>
using namespace std;
long long hcn(int a[],int n)
{
    int res=0;
    for(int i=0;i<n;i++)
    {
        int ht;//hiện tại
        ht=a[i];
    for(int j=i-1;j>=0&&a[j]>=a[i];j--)
    {
        ht+=a[i];
    }
    for(int j=i+1;j<n&&a[j]>=a[i];j++)
    {
        ht+=a[i];
    }
      res=max(res,ht);
    }
    return res;
}
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n;
        cin>>n;
        int a[n];
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }
        cout<<hcn(a,n)<<endl;
    }
}
