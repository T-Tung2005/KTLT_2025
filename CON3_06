#include<bits/stdc++.h>
using namespace std;
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n;
        cin>>n;
        vector<int>a(n),b;
        for(int i=0;i<n;i++) cin>>a[i];
        b=a;
        sort(b.begin(),b.end());
        bool check=true;
        int l=0;int r=n-1;
        while(l<r)
        {
            if(a[l]==b[l]&&a[r]==b[r])
            {
            }else if(a[l]==b[r]&&a[r]==b[l])
            {
                swap(a[l],a[r]);
            }else{
             check=false;
             break;
             }
             l++;r--;
        }
        if(check==true)
        {
            cout<<"Yes"<<endl;
        }else
        {
            cout<<"No"<<endl;
        }
    }
}
