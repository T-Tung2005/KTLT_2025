#include<bits/stdc++.h>
using namespace std;
long long timkiem(int a[], int n, int x) // tìm phần tử lớn nhaayt nhỏ hơn bằng x
{
    int res=-2;
    int l=0;
    int r=n-1;
    while(l<=r)
    {
        int mid=(l+r)/2;
       if(a[mid]<=x)
       {
           res=mid;
           l=mid+1;
       }else {
         r=mid-1;
       }
    }
    return res;
}
int main()
{
    int t;
    cin>>t;
    while(t--)
    {
        int n,k;
        cin>>n>>k;
        int a[n];
        for(int i=0;i<n;i++)
        {
            cin>>a[i];
        }
        sort(a,a+n);
        long long h=timkiem(a,n,k);
        cout<<h+1<<endl;
    }
}
