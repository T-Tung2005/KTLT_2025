#include<bits/stdc++.h>
using namespace std;
int dp[105][105];
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int c,n;
        cin>>c>>n;
        int w[100];
        for(int i=1;i<=n;i++)
        {
            cin>>w[i];
        }
        int dp[n+1][c+1];
        memset(dp,0,sizeof(dp));
        for(int i=1;i<=n;i++)
        {
            for(int j=1;j<=c;j++)
            {
                if(j>=w[i])
                {
                    dp[i][j]=max(dp[i-1][j],dp[i-1][j-w[i]]+w[i]);
                }else
                dp[i][j]=dp[i-1][j];
            }
        }
        cout<<dp[n][c]<<endl;
    }
}
