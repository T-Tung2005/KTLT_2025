#include<bits/stdc++.h>
using namespace std;
int a[100][100];
int dp[105][105];
int main()
{
    int q;
    cin>>q;
    while(q--)
    {
        int n,m;
        cin>>n>>m;
        int a[n+1][m+1];
        for(int i=1;i<=n;i++)
        {
            for(int j=1;j<=m;j++)
            {
                cin>>a[i][j];
                dp[i][j]=1e9;
            }
        }
        dp[1][1]=a[1][1];
        for(int j=2;j<=m;j++)
            dp[1][j] = dp[1][j-1] + a[1][j];
        for(int i=2;i<=n;i++)
            dp[i][1] = dp[i-1][1] + a[i][1];
        int min1=-1e9;
        for(int i=2;i<=n;i++)
        {
            for(int j=2;j<=m;j++)
            {
              dp[i][j]=min({
                           dp[i][j-1],
                           dp[i-1][j-1],
                           dp[i-1][j]
                           })+a[i][j];
            }
        }
        cout<<dp[n][m]<<endl;
    }
}
